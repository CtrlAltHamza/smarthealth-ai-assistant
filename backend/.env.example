PORT=5000
JWT_SECRET=supersecretkey_smarthealth

# Database mode: postgres | sqlite
DB_DIALECT=postgres

# Postgres settings (used when DB_DIALECT=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smarthealth
DB_USER=admin
DB_PASSWORD=adminpassword

# SQLite settings (used when DB_DIALECT=sqlite)
SQLITE_STORAGE=./smarthealth.sqlite

# AI service endpoint
AI_SERVICE_URL=http://127.0.0.1:8000

# Sequelize sync behavior
DB_SYNC_ALTER=false
